# Copy to .env.local and fill in.

# Single shared password for the whole app (one user, no registration).
APP_PASSWORD=change-me

# Neon PostgreSQL connection string.
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Cloudflare R2 (S3-compatible) — product image storage.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=atifarm
R2_PUBLIC_BASE_URL=https://pub-xxxxx.r2.dev

# Image search ("Намери снимка") — Google Programmable Search. Optional (Phase 2b).
IMAGE_SEARCH_API_KEY=
IMAGE_SEARCH_CX=
